# Modern CLI Standards (Zero-Conf Productivity)
brew "bat"    # Better cat
brew "eza"    # Modern ls
brew "fzf"    # Fuzzy finder
brew "zoxide" # Smarter cd
brew "tldr"   # Simplified manuals
brew "jq"     # JSON processor
brew "yq"     # YAML processor
brew "direnv" # Environment switcher
brew "glow"   # Markdown renderer
brew "duf"    # Disk usage visually
brew "btop"   # System monitor

# Bluefin/Bazzite Modern DX Taps
tap "ublue-os/tap"
cask "visual-studio-code-linux"
